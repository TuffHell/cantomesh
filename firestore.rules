rules_version = '2';

// CANTOMESH verse collection: each signed-in user can read/write ONLY their own
// verses at users/{uid}/verses/**. No cross-user access; nothing else is exposed.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/verses/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
